{
  "name": "interviewmind-backend",
  "version": "1.0.0",
  "description": "InterviewMind AI Node.js Express Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "prisma:generate": "prisma generate --schema=../database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../database/schema.prisma",
    "prisma:studio": "prisma studio --schema=../database/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.12.1"
  }
}
